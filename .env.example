# CreatorStack — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it's in .gitignore.

# ─── Firebase (Required) ────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General → Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── YouTube Data API v3 (Optional — enables real metrics) ──────────────────
# Get from: Google Cloud Console → APIs → YouTube Data API v3 → Credentials
# Leave blank to use estimate mode (still functional, no verified badge)
VITE_YOUTUBE_API_KEY=YOUR_YOUTUBE_DATA_API_V3_KEY_HERE

# ─── Razorpay (Required for real payments) ──────────────────────────────────
# Get from: Razorpay Dashboard → Settings → API Keys
# Use test keys (rzp_test_*) during development
# Use live keys (rzp_live_*) in production ONLY
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_here

# ─── Firebase Cloud Messaging / Push Notifications (Optional) ───────────────
# Get from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FCM_VAPID_KEY=your_vapid_key_here

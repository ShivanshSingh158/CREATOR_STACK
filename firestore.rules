rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && isOwner(uid);
    }

    // ── Creators (public discovery mirror) ───────────────────────────────────
    match /creators/{creatorId} {
      allow read: if isAuth();
      allow write: if isAuth() && isOwner(creatorId);
    }

    // ── Campaigns ───────────────────────────────────────────────────────────
    match /campaigns/{campaignId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.brandId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.brandId == request.auth.uid ||
        resource.data.creatorId == request.auth.uid
      );
      allow delete: if isAuth() && resource.data.brandId == request.auth.uid;
    }

    // ── Applications ─────────────────────────────────────────────────────────
    match /applications/{appId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isAuth();
    }

    // ── Deal Rooms ───────────────────────────────────────────────────────────
    match /dealRooms/{dealId} {
      allow read: if isAuth() && (
        resource.data.brandId == request.auth.uid ||
        resource.data.creatorId == request.auth.uid
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.brandId == request.auth.uid ||
        resource.data.creatorId == request.auth.uid
      );
    }

    // ── Chats ────────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read, update: if isAuth() && (
        resource.data.brandId == request.auth.uid ||
        resource.data.creatorId == request.auth.uid
      );
      allow create: if isAuth();
    }

    // ── Messages ─────────────────────────────────────────────────────────────
    match /messages/{msgId} {
      allow read: if isAuth() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
    }

    // ── Wallet Transactions (IMMUTABLE — no update/delete) ───────────────────
    match /walletTransactions/{txId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Admin Reviews ────────────────────────────────────────────────────────
    match /adminReviews/{reviewId} {
      allow create: if isAuth();
      allow read, update: if isAuth();
      allow delete: if false;
    }

    // ── Shortlists ────────────────────────────────────────────────────────────
    match /shortlists/{shortlistId} {
      allow read, write: if isAuth() && (
        resource == null || resource.data.brandId == request.auth.uid
      );
    }

    // ── Disputes ────────────────────────────────────────────────────────────
    match /disputes/{disputeId} {
      allow read: if isAuth() && (
        resource.data.brandId == request.auth.uid ||
        resource.data.creatorId == request.auth.uid
      );
      allow create, update: if isAuth();
    }

    // ── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }
  }
}
